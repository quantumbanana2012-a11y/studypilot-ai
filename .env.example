PORT=4174
HOST=0.0.0.0
PUBLIC_BASE_URL=https://your-domain.com
DATABASE_PATH=./data/zentradeck-db.json
# Render persistent disk example:
# DATABASE_PATH=/var/data/zentradeck-db.json

# Production assistant. Gemini has a free tier; use Render environment variables for the key.
MODEL_PROVIDER=gemini
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-2.0-flash

# OpenAI-compatible hosted model router fallback.
COMPATIBLE_API_BASE_URL=https://openrouter.ai/api/v1
COMPATIBLE_API_KEY=sk-or-v1_replace_me
COMPATIBLE_MODEL=openrouter/free
COMPATIBLE_FALLBACK_MODELS=google/gemma-3-27b-it:free,meta-llama/llama-3.3-70b-instruct:free,mistralai/mistral-7b-instruct:free
MODEL_TIMEOUT_MS=35000

# OpenAI option:
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=sk-proj_replace_me
# OPENAI_MODEL=gpt-5-mini

# Other OpenAI-compatible free/low-cost examples:
# Groq: COMPATIBLE_API_BASE_URL=https://api.groq.com/openai/v1
# Groq example model: COMPATIBLE_MODEL=llama-3.1-8b-instant
# Hugging Face: COMPATIBLE_API_BASE_URL=https://api-inference.huggingface.co/v1
# Hugging Face free credits are small, so it is better for prototypes than public launch.

# Local/dev only. Use MODEL_PROVIDER=ollama if you ever want local testing again.
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3:8b-q4_K_M

# Optional ads. Leave disabled for the free public launch.
ADS_ENABLED=false
ADSENSE_CLIENT_ID=ca-pub-replace_me
ADSENSE_SIDEBAR_SLOT=replace_sidebar_slot
ADSENSE_WORKSPACE_SLOT=replace_workspace_slot
